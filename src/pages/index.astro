---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  aboutParagraphs,
  blogs,
  contactLinks,
  educationAndHonors,
  experience,
  quickFacts,
  researchArtifacts,
  siteMeta,
  writingIdeas,
} from "../data/site";

const news = [
  { date: "2025.07", text: 'Joined <strong>ByteDance Seed</strong> as research intern, VLM post-training team.' },
  { date: "2025.04", text: '<a href="https://arxiv.org/abs/2504.16074">PHYBench</a> preprint released on arXiv. Submitted to NeurIPS 2025.' },
  { date: "2025.03", text: 'Started contributing to VLA models survey (action tokenization perspective).' },
  { date: "2024.12", text: 'Awarded <strong>National Scholarship</strong> (top 1% at PKU).' },
];
---

<BaseLayout pageTitle={siteMeta.name} pageDescription={siteMeta.summary} pagePath="/">

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-layout">
      <div class="hero-content">
        <h1 class="hero-name hero-anim">
          Shaoyang Guo<span class="hero-name-cn">郭绍阳</span>
        </h1>
        <p class="hero-tagline hero-anim">
          Physics undergraduate at Peking University. Research intern at ByteDance Seed.
          Working on VLM post-training, STEM reasoning evaluation, and data-centric AI.
        </p>
        <div class="hero-affiliation hero-anim">
          <span><strong>Peking University</strong>, School of Physics (Class of 2027)</span>
          <span>Excellence Program &middot; CPhO Gold Medalist</span>
        </div>
        <div class="hero-links hero-anim">
          <a class="hero-link" href={siteMeta.github} target="_blank" rel="noreferrer">GitHub</a>
          <a class="hero-link" href={`mailto:${siteMeta.email}`}>Email</a>
          <a class="hero-link" href="https://arxiv.org/abs/2504.16074" target="_blank" rel="noreferrer">PHYBench</a>
          <a class="hero-link" href="/cv/">CV</a>
        </div>
        <div class="interests-row hero-anim">
          <span class="interest-tag">Physics of AI</span>
          <span class="interest-tag">Embodied Intelligence</span>
          <span class="interest-tag">VLM</span>
        </div>
      </div>
      <div class="hero-photo hero-photo-anim">
        <div class="hero-photo-frame">
          <img src="/images/photo.png" alt="Shaoyang Guo at NeurIPS 2025" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NEWS ===== -->
  <section class="section" id="news">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">News</h2>
      </div>
      <div class="news-list reveal reveal-delay-1">
        {news.map((item) => (
          <div class="news-item">
            <span class="news-date">{item.date}</span>
            <span class="news-text" set:html={item.text} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PUBLICATIONS ===== -->
  <section class="section" id="publications">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">Publications</h2>
      </div>
      <div class="pub-list">
        <article class="pub-item reveal reveal-delay-1">
          <div class="pub-thumbnail">
            <img src="/images/phybench.svg" alt="PHYBench" />
          </div>
          <div class="pub-content">
            <span class="pub-venue">NeurIPS 2025 (submitted)</span>
            <h3 class="pub-title">PHYBench: Holistic Evaluation of Physical Perception and Reasoning in Large Language Models</h3>
            <p class="pub-authors">Shi Qiu*, <strong>Shaoyang Guo*</strong>, et al.</p>
            <p class="pub-description">
              A comprehensive physics reasoning benchmark with 500 original problems contributed by 178 PKU students. Designed evaluation criteria and failure mode analysis for open-ended scientific reasoning.
            </p>
            <div class="pub-links">
              <a class="pub-link" href="https://arxiv.org/abs/2504.16074" target="_blank" rel="noreferrer">arXiv</a>
              <a class="pub-link" href="https://phybench.github.io" target="_blank" rel="noreferrer">Project Page</a>
            </div>
          </div>
        </article>

        <article class="pub-item reveal reveal-delay-2">
          <div class="pub-thumbnail">
            <img src="/images/vla-survey.svg" alt="VLA Survey" />
          </div>
          <div class="pub-content">
            <span class="pub-venue">arXiv Preprint</span>
            <h3 class="pub-title">A Survey on Vision-Language-Action Models: An Action Tokenization Perspective</h3>
            <p class="pub-authors">Authors including <strong>Shaoyang Guo</strong></p>
            <p class="pub-description">
              A survey on VLA models focusing on action representation. Responsible for the Raw Action chapter, reviewing 30+ key papers on end-to-end VLA architectures.
            </p>
            <div class="pub-links">
              <a class="pub-link" href="https://arxiv.org/abs/2507.01925" target="_blank" rel="noreferrer">arXiv</a>
              <a class="pub-link" href="https://github.com/Psi-Robot/Awesome-VLA-Papers" target="_blank" rel="noreferrer">GitHub</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== EXPERIENCE ===== -->
  <section class="section" id="experience">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">Experience</h2>
      </div>
      <div class="experience-list">
        {experience.map((item, i) => (
          <div class={`exp-item reveal reveal-delay-${i + 1}`}>
            <div class="exp-period">{item.period}</div>
            <div class="exp-content">
              <h3 class="exp-role">{item.role}</h3>
              <p class="exp-org">{item.org}</p>
              <p class="exp-description">{item.description}</p>
              <ul class="exp-bullets">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== BLOGS ===== -->
  <section class="section" id="blogs">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">Blogs</h2>
        <p class="section-subtitle">Ideas and working notes on AI, physics, and research taste.</p>
      </div>
      <div class="blogs-grid">
        {blogs.map((blog, i) => (
          <article class={`blog-card reveal reveal-delay-${i + 1}`}>
            <div class="blog-image">
              <img src={blog.image} alt={blog.title} />
            </div>
            <div class="blog-body">
              <span class="blog-eyebrow">{blog.eyebrow}</span>
              <h3 class="blog-title">{blog.title}</h3>
              <p class="blog-summary">{blog.summary}</p>
              <div class="blog-tags">
                {blog.tags.map((tag) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              {blog.link ? (
                <a class="blog-card-link" href={blog.link} target="_blank" rel="noreferrer">
                  Read &rarr;
                </a>
              ) : (
                <span class="blog-card-link" style="color: var(--text-muted);">Draft coming soon</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== EDUCATION ===== -->
  <section class="section" id="education">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">Education & Honors</h2>
      </div>
      <div class="edu-grid">
        {educationAndHonors.map((item, i) => (
          <article class={`edu-card reveal reveal-delay-${i + 1}`}>
            <h3 class="edu-title">{item.title}</h3>
            <p class="edu-detail">{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <section class="section" id="contact">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-title">Contact</h2>
        <p class="section-subtitle">
          Open to research collaboration, especially in VLM post-training, evaluation, and embodied intelligence.
        </p>
      </div>
      <div class="contact-grid reveal reveal-delay-1">
        {contactLinks.map((item) => (
          <a
            class="contact-card"
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noreferrer" : undefined}
          >
            <span class="contact-label">{item.label}</span>
            <span class="contact-value">{item.value}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
